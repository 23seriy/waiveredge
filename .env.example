# Copy to backend/.env and fill in. The scoring prototype needs NONE of these.

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://waiveredge:waiveredge@localhost:5432/waiveredge

# balldontlie API key — get one at https://app.balldontlie.io
# Stats (/v1/stats) and injuries (/v1/player_injuries) require the ALL-STAR tier ($9.99/mo).
BALLDONTLIE_API_KEY=
BALLDONTLIE_BASE_URL=https://api.balldontlie.io

# Current NBA season (start year)
SEASON=2025

# Comma-separated allowed CORS origins for the API
CORS_ORIGINS=http://localhost:3000
