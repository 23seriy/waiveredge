# =============================================================================
# WaiverEdge Backend — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# --- Postgres (required) ---
# Neon:    postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/waiveredge?sslmode=require
# Supabase: postgresql+psycopg2://postgres:pass@db.xxx.supabase.co:5432/postgres
# Local:   postgresql+psycopg2://waiveredge:waiveredge@localhost:5432/waiveredge
DATABASE_URL=postgresql+psycopg2://waiveredge:waiveredge@localhost:5432/waiveredge

# --- CORS (required for production) ---
# Comma-separated list of allowed frontend origins.
# Local dev + your production domain.
CORS_ORIGINS=http://localhost:3000,https://localhost:3000
# Optional regex for extra allowed origins (e.g. Vercel preview deploys).
# Leave empty unless you need it — a wildcard host with credentials is unsafe.
# Example (scope to YOUR project): https://waiveredge-[a-z0-9-]+\.vercel\.app
CORS_ORIGIN_REGEX=

# --- App secret (required — change for production!) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET=change-me-in-production

# --- Yahoo OAuth 2.0 (optional — needed for Yahoo league imports) ---
# Register at https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://your-backend.onrender.com/api/auth/yahoo/callback
YAHOO_GAME_KEY=nba

# --- Stripe billing (optional — without it, paywall is bypassed in dev mode) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_SEASON_PRICE_ID=

# --- OpenAI (optional — enables LLM-generated rationales) ---
OPENAI_API_KEY=

# --- Sentry error monitoring (optional — free tier: 5k errors/mo) ---
# https://sentry.io → Create project → Python/FastAPI
SENTRY_DSN=

# --- Balldontlie API (optional — for NBA production data feed) ---
BALLDONTLIE_API_KEY=
BALLDONTLIE_BASE_URL=https://api.balldontlie.io

# --- Season ---
SEASON=2025
